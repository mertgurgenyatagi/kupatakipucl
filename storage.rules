rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos are public within the app (shown to other participants),
    // so any signed-in user can read. Only the owner can upload their own,
    // capped at 5MB and restricted to image files.
    match /profile-photos/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
