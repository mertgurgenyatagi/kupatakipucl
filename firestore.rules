rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Profiles: name + photo are shown to other participants (SPEC §8/§4),
    // so any signed-in user can read them. Only the owner can write their own.
    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Survey responses feed aggregate stats only (SPEC §8d) and are never
    // shown per-user, so only the owner may read/write their own — and it's
    // one-time-only (SPEC §5), so no updates or deletes once created.
    match /surveyResponses/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false;
    }

    // Predictions: any signed-in user can read (matches the "trust the
    // friend group" stance already applied to chat/forum in SPEC §6 — the
    // app UI hides others' predictions until the tournament starts, but
    // this project has no adversarial threat model). Only the owner writes.
    match /predictions/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
