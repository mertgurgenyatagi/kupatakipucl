rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Profiles: name + photo are shown to signed-out visitors too (SPEC §8's
    // logged-out player list) as well as other participants (SPEC §8/§4), so
    // read is public. Only the owner can write their own.
    match /profiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Survey responses: readable by any signed-in participant (reversed
    // 2026-07-23 from owner-only — the participant popup's quiz-answers
    // widget shows other participants' answers directly, Mert's explicit
    // call, overriding SPEC.md §4/§8d's earlier "aggregate-only" stance; see
    // SPEC.md's changelog for the reversal). Still owner-only to create, and
    // one-time-only (SPEC §5) — no updates or deletes once created.
    match /surveyResponses/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false;
    }

    // Predictions: read is public (matches the "trust the friend group"
    // stance already applied to chat/forum in SPEC §6, and SPEC §8's
    // requirement that predictions become visible to signed-out visitors
    // too once the tournament starts — the app UI hides others' predictions
    // until then; this project has no adversarial threat model). Only the
    // owner writes.
    match /predictions/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Team results feed the team table and score computation (SPEC.md §3, §8b),
    // shown to signed-out visitors too (SPEC §8's logged-out live rankings).
    // No admin UI (SPEC.md §7b) — normally maintained via direct Firestore
    // edits. Temporarily opened to any signed-in write pre-launch so the dev
    // panel (src/devpanel) can push synthetic standings from the browser;
    // tighten back to `if false` once results automation/admin tooling lands.
    match /results/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Dev-only tooling (src/devpanel): simulates tournament phase/date and
    // match outcomes so timing-dependent features can be tested without
    // waiting on real calendar dates. Pre-launch, no real users yet — same
    // trust stance as the rest of this file. Remove once results automation
    // (SPEC.md §7, currently skipped) makes this panel unnecessary.
    match /devConfig/{docId} {
      allow read, write: if request.auth != null;
    }
    match /devMatches/{fixtureId} {
      allow read, write: if request.auth != null;
    }

    // Chat messages: logged-in only (matches the "chat" page's own gate in
    // pageAccess.ts — SPEC.md §8 shows no chatroom to logged-out visitors in
    // either state, unlike profiles/predictions/results). A user can only
    // create a message attributed to their own uid. Permanent scrollback, no
    // admin panel (SPEC.md §6, §7b) — no edits or deletes, ever, by anyone.
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Forum posts: public read (pageAccess.ts allows the logged-out ST_NLI
    // state to view the forum — unlike chat, which is logged-in only in
    // every state). A user can only create a post attributed to their own
    // uid. Immutable, no admin panel (SPEC.md §6, §7b) — no edits/deletes.
    match /forumPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
